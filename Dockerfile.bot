# Immagine per il bot Telegram: Python + ffmpeg + yt-dlp
# Per hosting 24/7 (Railway, Fly.io, ecc.): imposta TELEGRAM_BOT_TOKEN
FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends ffmpeg \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY bot.py yt_portrait.py ./

# Il token va impostato come variabile d'ambiente (TELEGRAM_BOT_TOKEN)
CMD ["python", "bot.py"]
